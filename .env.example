# Copy to .env, fill in once the Supabase + Vercel projects exist (see the plan doc).

# Supabase dashboard -> Connect -> Framework tab
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<publishable-key>"

# Supabase dashboard -> Connect -> ORM tab -> Prisma
# DATABASE_URL: transaction-mode pooler — used by the running app (lib/db.ts)
# DIRECT_URL:   session-mode pooler — used only for migrations (prisma.config.ts)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres"

# After running the Prisma migration for the first time, also run
# supabase/sync_auth_users.sql once in the Supabase SQL Editor — it keeps
# public.users in sync with auth.users on sign-up.

# Optional — availability check-in notification emails (lib/email.ts).
# Without these, the in-app half of the feature still works; emails are
# just skipped (logged as a warning) until both are set. Generate a fresh
# Resend API key for the app (separate from the one in Supabase's SMTP
# config), and use the same verified sending domain as the magic links.
RESEND_API_KEY="re_..."
NOTIFICATIONS_FROM_EMAIL="noreply@yourdomain.com"
